PORT=8000 # Port to listen on
MAX_WS_CONNECTIONS=500 # Max number of concurrent WebSocket connections
RL_BUCKET_CAPACITY=5 # Max burst — how many rapid reconnects are allowed
RL_REFILL_RATE=1 # How many tokens are added per refill interval
RL_REFILL_INTERVAL_MS=10000 # How often the tokens are refilled (in milliseconds)